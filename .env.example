# 直播电商数据分析平台 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# .env 已在 .gitignore 中，不会被提交到 Git

# MySQL
MYSQL_HOST=hadoop01
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=live_analytics

# Kafka
KAFKA_BROKERS=hadoop01:9092,hadoop02:9092,hadoop03:9092

# Hive
HIVE_DB=live_dw
HDFS_BASE=/user/hive/warehouse/live

# JWT
JWT_SECRET_KEY=your_secret_key_here
API_PORT=8002

# 抖音直播 Cookie (会过期，在浏览器F12→Network→请求头中获取)
DOUYIN_COOKIE=your_douyin_cookie_here
